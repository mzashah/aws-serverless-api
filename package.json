{
  "name": "aws-serverless-api",
  "version": "1.0.0",
  "description": "AWS Serverless REST API with Lambda, DynamoDB, API Gateway, Cognito & CDK",
  "private": true,
  "scripts": {
    "build": "tsc",
    "cdk:deploy": "cd cdk && cdk deploy --all",
    "cdk:synth": "cd cdk && cdk synth",
    "cdk:diff": "cd cdk && cdk diff",
    "cdk:destroy": "cd cdk && cdk destroy --all",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/node": "^20.14.0",
    "aws-cdk": "^2.147.0",
    "aws-cdk-lib": "^2.147.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.21.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2"
  },
  "engines": { "node": ">=20.0.0" },
  "license": "MIT"
}
